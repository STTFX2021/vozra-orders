# ── VOZRA PRINT AGENT — configuración por local ──────────────────────────────
# Copia este archivo a ".env" y rellena los valores de ESTE local.

# URL pública del backend en Railway (sin barra final)
RAILWAY_URL=https://vozra-orders-production.up.railway.app

# Debe COINCIDIR con PRINT_AGENT_SECRET del backend (o su ELEVENLABS_CUSTOM_LLM_SECRET)
AGENT_SECRET=

# ── Impresora de cocina ──────────────────────────────────────────────────────
# Lo ÚNICO que cambia entre locales: la IP de su impresora térmica (Epson TM, etc.)
PRINTER_IP=192.168.1.50
PRINTER_PORT=9100

# Ancho del papel en caracteres (58mm≈32, 80mm≈48)
PRINTER_WIDTH=48

# Cada cuántos ms pregunta por pedidos nuevos
POLL_MS=4000

# Modo simulador: 1 = NO imprime, escribe la comanda en ./tickets/ (para probar sin hardware)
SIMULATE=0
