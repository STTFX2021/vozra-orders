# VOZRA ORDERS — Variables de entorno requeridas
# Copiar a .env y rellenar los valores reales. Nunca subir .env a git.

# ── Telegram Bot (canal primario de dispatch) ────────────────────────────────
# Crear un bot en @BotFather y añadirlo al grupo de cocina.
# TELEGRAM_CHAT_ID: ID del grupo/canal de cocina (número negativo para grupos).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Override por proveedor (opcional — si vacío se usan los anteriores)
TELEGRAM_BOT_TOKEN_LA_LOCANDA=
TELEGRAM_CHAT_ID_LA_LOCANDA=

# ── Discord Webhook (canal secundario de dispatch) ───────────────────────────
# Crear en Discord: Canal → Editar canal → Integraciones → Webhooks → Crear webhook
DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK_URL_LA_LOCANDA=

# ── File Fallback ─────────────────────────────────────────────────────────────
# Directorio donde se guardan los pedidos cuando todos los canales fallan.
# Relativo al directorio raíz del proyecto (vozra-orders/).
FALLBACK_ORDERS_DIR=../orders_fallback

# ── ElevenLabs Custom LLM (canal de voz) ─────────────────────────────────────
# Token secreto para autenticar las llamadas de ElevenLabs al servidor.
# Puede ser cualquier string aleatorio (ej: openssl rand -hex 32).
ELEVENLABS_CUSTOM_LLM_SECRET=

# ── OpenAI (Whisper STT + Vision para WhatsApp multimodal) ───────────────────
# Necesario para transcribir audios OPUS/OGG y describir imágenes de WhatsApp.
OPENAI_API_KEY=

# ── Twilio (canal WhatsApp) ───────────────────────────────────────────────────
# Obtener en console.twilio.com → Account Info.
# TWILIO_SKIP_SIGNATURE=true solo para desarrollo local (nunca en producción).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SKIP_SIGNATURE=false

# ── Vapi (alternativa de voz — opcional) ──────────────────────────────────────
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=

# ── Supabase (Fase 8+ — persistencia de pedidos) ─────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
